							"mode": "raw",
							"raw": "{\n    \"username\": \"Savoeun2034\",\n    \"password\": \"Savoeun123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"login"
							]
						}
					},
					"response": []
				},
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"Savoeun2034\",\n    \"password\": \"Savoeun123\",\n    \"email\": \"savoeun@example.com\",\n    \"firstName\": \"Savoeun\",\n    \"lastName\": \"User\",\n    \"phoneNumber\": \"012345678\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"register"
							]
						}
					},
					"response": []
				},
				{
